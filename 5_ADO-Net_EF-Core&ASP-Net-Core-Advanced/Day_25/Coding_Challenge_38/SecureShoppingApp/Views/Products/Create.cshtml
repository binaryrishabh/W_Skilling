@model SecureShoppingApp.Models.Product

<h2>Add Product</h2>
<form method="post">
    <div>Name: <input asp-for="Name" class="form-control" /></div>
    <div>Price: <input asp-for="Price" class="form-control" /></div>
    <div>Description: <textarea asp-for="Description" class="form-control"></textarea></div>
    <button type="submit" class="btn btn-success mt-2">Create</button>
</form>