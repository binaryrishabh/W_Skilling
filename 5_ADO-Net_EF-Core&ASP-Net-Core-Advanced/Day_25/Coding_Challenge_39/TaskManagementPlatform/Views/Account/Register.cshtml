@model TaskManagementPlatform.Models.RegisterViewModel
<form method="post" asp-action="Register" asp-controller="Account">
    @Html.AntiForgeryToken()
    <input asp-for="FirstName" placeholder="First Name" />
    <input asp-for="Username" placeholder="Username" />
    <input asp-for="Password" type="password" placeholder="Password" />
    <input asp-for="ConfirmPassword" type="password" placeholder="Confirm Password" />
    <button type="submit">Register</button>
</form>