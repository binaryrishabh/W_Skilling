@page "{id}"
@using _1_AdvancedRazorPages.Models
@model _1_AdvancedRazorPages.Pages.ProductDetailsModel

<h2>Product Details</h2>
<p><strong>ID:</strong> @Model.Product?.ProductID</p>
<p><strong>Name:</strong> @Model.Product?.Name</p>
<p><strong>Description:</strong> @Model.Product?.Description</p>
<h4>Categories:</h4>
<ul>
    @foreach (var cat in Model.Product?.Categories ?? new List<Category>()) {
        <li>@cat.Name</li>
    }
</ul>
<a href="/Products">Back to List</a>