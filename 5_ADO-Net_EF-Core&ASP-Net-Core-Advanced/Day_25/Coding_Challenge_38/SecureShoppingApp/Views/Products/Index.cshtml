@model IEnumerable<SecureShoppingApp.Models.Product>

<h2>Products</h2>
@foreach (var p in Model)
{
    <div>
        <h3>@p.Name</h3>
        <p>₹@p.Price</p>
        <p>@Html.Raw(System.Net.WebUtility.HtmlEncode(p.Description))</p>
    </div>
}
@if (User.IsInRole("Admin"))
{
    <a href="/Products/Create" class="btn btn-primary">Add Product</a>
}