@model _1_AdvancedRazorPages.Models.Product

<div style="border:1px solid #ccc; margin:10px; padding:10px">
    <h3>@Model.Name</h3>
    <p>@Model.Description</p>
    <h4>Categories:</h4>
    <ul>
        @foreach (var cat in Model.Categories) {
            <li>@cat.Name</li>
        }
    </ul>
</div>