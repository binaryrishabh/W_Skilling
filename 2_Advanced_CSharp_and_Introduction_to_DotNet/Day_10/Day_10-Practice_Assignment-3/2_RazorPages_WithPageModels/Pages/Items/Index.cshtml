@page
@model _2_RazorPages_WithPageModels.Pages.Items.IndexModel
<h2>Item List</h2>
<table border="1">
    <tr><th>ID</th><th>Name</th><th>Added By</th></tr>
    @foreach (var item in Model.Items) {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.AddedBy</td>
        </tr>
    }
</table>
<a href="/Items/Create">Add New Item</a>