@{
    ViewData["Title"] = "Product Price Lookup";
}

<div class="container mt-5">
    <h2>Find Product Price</h2>
    
    <div class="form-group mt-4">
        <label>Enter Product ID (1, 2, or 3):</label>
        <input type="number" id="productId" class="form-control w-50" />
        <button id="btnGetPrice" class="btn btn-primary mt-3">Get Price</button>
    </div>

    <div id="result" class="alert alert-success mt-3" style="display:none"></div>
    <div id="error" class="alert alert-danger mt-3" style="display:none"></div>
    <div id="loading" class="mt-3" style="display:none">Loading...</div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $("#btnGetPrice").click(function() {
                var id = $("#productId").val();
                
                if (id == "") {
                    alert("Please enter Product ID");
                    return;
                }
                
                $("#loading").show();
                $("#result").hide();
                $("#error").hide();
                
                $.ajax({
                    url: '/Product/GetPrice',
                    type: 'POST',
                    data: { id: id },
                    success: function(response) {
                        $("#loading").hide();
                        if (response.success) {
                            $("#result").html("Product: " + response.name + "<br/>Price: ₹" + response.price).show();
                        } else {
                            $("#error").html(response.message).show();
                        }
                    },
                    error: function() {
                        $("#loading").hide();
                        $("#error").html("Something went wrong").show();
                    }
                });
            });
        });
    </script>
}