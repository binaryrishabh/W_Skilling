<!DOCTYPE html>
<html>
<head>
    <title>Secure Shop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">SecureShop</a>
            @if (User.Identity.IsAuthenticated)
            {
                <span class="text-white">Hello @User.Identity.Name</span>
                <a href="/Account/Logout" class="btn btn-danger btn-sm">Logout</a>
            }
            else
            {
                <a href="/Account/Login" class="btn btn-primary btn-sm">Login</a>
            }
        </div>
    </nav>
    <div class="container mt-4">
        @RenderBody()
    </div>
</body>
</html>